{
  "author": "github.com/161043261",
  "description": "homepage",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "vitepress": "^1.6.4"
  },
  "keywords": [
    "homepage"
  ],
  "license": "ISC",
  "lint-staged": {
    "docs/*.{json,jsonc,js,cjs,mjs,jsx,ts,cts,mts,tsx,html,vue,css,scss,md,mdx}": [
      "pnpm format"
    ]
  },
  "name": "homepage",
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "build": "rm -rf ./vitepress/dist && vitepress build",
    "dev": "vitepress dev",
    "format": "prettier --write ./docs .vitepress/theme",
    "prepare": "husky",
    "preview": "vitepress preview"
  },
  "type": "module",
  "version": "1.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "next": "16.2.1",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
